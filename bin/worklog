#!/usr/bin/env python3
"""worklog CLI — backs the /worklog:* slash commands.

Subcommands:
  init                       Create the SQLite database and tables.
  add                        Add a task or timesheet entry.
  show [date]                Show tasks + timesheet for date (default: today).
  list-pending [date]        Print tasks not yet pushed to ClickUp, as JSON.
  link-task <id> <cu-id>     Record ClickUp task id against a local task.
  set-project-list <p> <id>  Map a project to a default ClickUp list id.

Date forms: today | yesterday | YYYY-MM-DD
"""
from __future__ import annotations

import argparse
import json
import sys
from datetime import date as _date, datetime, timedelta
from pathlib import Path

# Allow importing the sibling lib/ package regardless of cwd
ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(ROOT))

from lib import db  # noqa: E402


# --- Rendering: ANSI for TTY, markdown for everything else ----------------
# Auto-detected so Claude Code (which captures stdout) keeps getting the
# markdown it can render, while a plain terminal sees colourised output.
_TTY = sys.stdout.isatty()

if _TTY:
    _RESET = "\x1b[0m"
    def _bold(s):    return f"\x1b[1m{s}{_RESET}"
    def _italic(s):  return f"\x1b[3m{s}{_RESET}"
    def _dim(s):     return f"\x1b[2m{s}{_RESET}"
    def _heading(s): return f"\x1b[1;36m{s}{_RESET}"   # bold cyan
    def _subhead(s): return f"\x1b[1;34m{s}{_RESET}"   # bold blue
    def _code(s):    return f"\x1b[33m{s}{_RESET}"     # yellow
    def _ok(s):      return f"\x1b[32m{s}{_RESET}"     # green
    def _link(label, url):
        # OSC 8 hyperlink (modern terminals: kitty, iTerm2, recent gnome-terminal, Windows Terminal)
        return f"\x1b]8;;{url}\x1b\\{label}\x1b]8;;\x1b\\"
else:
    def _bold(s):    return f"**{s}**"
    def _italic(s):  return f"_{s}_"
    def _dim(s):     return f"_{s}_"
    def _heading(s): return f"# {s}"
    def _subhead(s): return f"## {s}"
    def _code(s):    return f"`{s}`"
    def _ok(s):      return f"**{s}**"
    def _link(label, url):
        return f"[{label}]({url})"


def _file_url(path: str) -> str:
    """Convert an absolute filesystem path to a file:// URL."""
    from urllib.parse import quote
    return "file://" + quote(path, safe="/")


_ANSI_RE = None  # lazy-compiled

def _visible_width(s: str) -> int:
    """Length of s ignoring ANSI colour codes and OSC 8 hyperlinks."""
    global _ANSI_RE
    if _ANSI_RE is None:
        import re
        _ANSI_RE = re.compile(
            r"\x1b\[[0-9;]*m"                    # CSI colour
            r"|\x1b\]8;[^\x07\x1b]*(?:\x07|\x1b\\)"  # OSC 8 open/close
        )
    return len(_ANSI_RE.sub("", s))


def _render_table(headers, rows):
    """Print a table — Unicode box-drawing in TTY, markdown when piped."""
    widths = [_visible_width(h) for h in headers]
    for row in rows:
        for i, cell in enumerate(row):
            widths[i] = max(widths[i], _visible_width(cell))

    def pad(cell, w):
        return cell + " " * (w - _visible_width(cell))

    if _TTY:
        top    = "┌─" + "─┬─".join("─" * w for w in widths) + "─┐"
        mid    = "├─" + "─┼─".join("─" * w for w in widths) + "─┤"
        bot    = "└─" + "─┴─".join("─" * w for w in widths) + "─┘"
        def row_line(cells):
            return "│ " + " │ ".join(pad(c, w) for c, w in zip(cells, widths)) + " │"
        print(top)
        print(row_line([_bold(h) for h in headers]))
        print(mid)
        for r in rows:
            print(row_line(r))
        print(bot)
    else:
        print("| " + " | ".join(headers) + " |")
        print("|" + "|".join("-" * max(3, w + 2) for w in widths) + "|")
        for r in rows:
            print("| " + " | ".join(r) + " |")


def parse_date(s: str | None) -> str:
    if not s or s == "today":
        return _date.today().isoformat()
    if s == "yesterday":
        return (_date.today() - timedelta(days=1)).isoformat()
    # validate YYYY-MM-DD
    return datetime.strptime(s, "%Y-%m-%d").date().isoformat()


def hhmm_to_min(t: str) -> int:
    h, m = t.split(":")
    return int(h) * 60 + int(m)


def cmd_init(_a):
    path = db.db_path()
    pre_existed = path.exists() and path.stat().st_size > 0
    db.init()
    print(f"{'Already initialised at' if pre_existed else 'Initialised'} {path}")


def cmd_add_task(a):
    tid = db.add_task(
        project=a.project,
        task=a.task,
        date=parse_date(a.date),
        reference=a.ref or "",
        assigned=a.assigned or "",
        status=a.status,
        remark=a.remark or "",
        source=a.source,
    )
    print(f"task #{tid} added")


def cmd_add_time(a):
    since, upto = a.since, a.upto
    mins = hhmm_to_min(upto) - hhmm_to_min(since)
    if mins < 0:
        mins += 24 * 60
    tid = db.add_timesheet(
        date=parse_date(a.date),
        since=since,
        upto=upto,
        minutes=mins,
        project=a.project,
        task=a.task,
        ref=a.ref or "",
        source=a.source,
    )
    print(f"timesheet #{tid} added ({mins // 60:02d}:{mins % 60:02d})")


def cmd_add_project(a):
    pid = db.add_project(
        name=a.name,
        path=a.path,
        coordinator=a.coordinator or "",
        git_repo=a.repo or "",
        auto_log=not a.no_auto_log,
    )
    where = f" at {a.path}" if a.path else ""
    autolog = "on" if not a.no_auto_log else "off"
    print(f"project #{pid} '{a.name}' registered{where} (auto-log: {autolog})")


def cmd_projects(a):
    from pathlib import Path as _Path
    rows = db.list_projects_with_status()
    if a.format == "json":
        print(json.dumps([dict(r) for r in rows], indent=2))
        return
    if not rows:
        print(_italic("no projects registered yet — use "
                      "`worklog project register --path <dir>`"))
        return

    table_rows = []
    for r in rows:
        if r["path"]:
            exists = _ok("yes") if _Path(r["path"]).exists() else _bold("no")
            path_cell = _link(_code(r["path"]), _file_url(r["path"]))
        else:
            exists = "—"
            path_cell = "—"
        autolog = _ok("on") if r["auto_log"] else _dim("off")
        cu = _clickup_breadcrumb(r) or _dim("—")
        last = r["last_active"] or _dim("—")
        table_rows.append([
            str(r["id"]),
            r["name"],
            path_cell,
            exists,
            autolog,
            cu,
            last,
        ])

    _render_table(
        ["#", "Project", "Path", "Path exists", "Auto-log", "ClickUp", "Last active"],
        table_rows,
    )


def _remove_time(ts_id: int) -> int:
    ok = db.delete_timesheet(ts_id)
    print(f"timesheet #{ts_id} removed" if ok else f"timesheet #{ts_id} not found")
    return 0 if ok else 1


def _remove_task(task_id: int) -> int:
    ok = db.delete_task(task_id)
    print(f"task #{task_id} removed" if ok else f"task #{task_id} not found")
    return 0 if ok else 1


def cmd_remove(a):
    """Accepts:
        worklog remove <id>          → delete timesheet row
        worklog remove time <id>     → same, explicit
        worklog remove task <id>     → delete tasks row
    """
    first = a.kind_or_id
    # Bare-id shorthand: `worklog remove 4`
    if first.isdigit():
        if a.id is not None:
            print("error: id given twice", file=sys.stderr)
            return 2
        return _remove_time(int(first))
    if first not in ("time", "task"):
        print(f"error: unknown kind '{first}' (use 'time', 'task', or a numeric id)",
              file=sys.stderr)
        return 2
    if a.id is None:
        print(f"error: missing id (usage: worklog remove {first} <id>)",
              file=sys.stderr)
        return 2
    return _remove_time(a.id) if first == "time" else _remove_task(a.id)


def cmd_project_register(a):
    from pathlib import Path as _Path
    path = str(_Path(a.path).expanduser().resolve())
    name = a.name or _Path(path).name
    pid = db.add_project(
        name=name,
        path=path,
        coordinator=a.coordinator or "",
        git_repo=a.repo or "",
        auto_log=True,
    )
    print(f"project #{pid} '{name}' registered at {path} (auto-log: on)")


def cmd_project_untrack(a):
    from pathlib import Path as _Path
    path = str(_Path(a.path).expanduser().resolve())
    row = db.set_project_auto_log_by_path(path, enabled=False)
    if not row:
        print(f"no project registered covering {path}")
        return 1
    print(f"project '{row['name']}' ({row['path']}) — auto-log now OFF")


def _clickup_breadcrumb(row):
    """Returns a ' / '-joined ClickUp breadcrumb with each segment linked
    (markdown link in piped mode, OSC 8 in TTY). Empty string if no mapping."""
    ws = row["clickup_workspace_id"]
    parts = []
    for seg_id, seg_name, url_template in (
        (row["clickup_space_id"],  row["clickup_space_name"],  "v/o/s"),
        (row["clickup_folder_id"], row["clickup_folder_name"], "v/o/f"),
        (row["clickup_list_id"],   row["clickup_list_name"],   "v/li"),
    ):
        if not (seg_id or seg_name):
            continue
        label = seg_name or seg_id
        if ws and seg_id:
            parts.append(_link(label,
                               f"https://app.clickup.com/{ws}/{url_template}/{seg_id}"))
        else:
            parts.append(label)
    return " / ".join(parts)


def cmd_project_show(a):
    from pathlib import Path as _Path
    row = None
    if a.id is not None:
        with db.connect() as c:
            row = c.execute("SELECT * FROM projects WHERE id=?", (a.id,)).fetchone()
    elif a.name:
        row = db.get_project(a.name)
    elif a.path:
        row = db.get_project_by_path(a.path)
    else:
        print("error: pass --id, --name or --path", file=sys.stderr)
        return 2
    if not row:
        print("error: project not found", file=sys.stderr)
        return 1

    path_cell = (_link(_code(row["path"]), _file_url(row["path"]))
                 if row["path"] else "—")
    exists = (_ok("yes") if row["path"] and _Path(row["path"]).exists()
              else (_bold("no") if row["path"] else "—"))
    autolog = _ok("on") if row["auto_log"] else _dim("off")
    cu = _clickup_breadcrumb(row) or _dim("not mapped")
    print(f"{_bold(row['name'])} (#{row['id']})")
    print(f"  path     : {path_cell}  ({exists})")
    print(f"  auto-log : {autolog}")
    print(f"  ClickUp  : {cu}")


def cmd_project_remove(a):
    if a.id is None and not a.name:
        print("error: pass --id <N> or --name <project>", file=sys.stderr)
        return 2
    target_id = a.id
    if target_id is None:
        row = db.get_project(a.name)
        if not row:
            print(f"error: no project named '{a.name}'", file=sys.stderr)
            return 1
        target_id = row["id"]
    status = db.delete_project(target_id)
    if status == "not_found":
        print(f"error: project #{target_id} not found", file=sys.stderr)
        return 1
    if status == "in_use":
        print(f"error: project #{target_id} still has tasks or timesheet "
              f"rows referencing it. Remove those first (or use "
              f"`worklog project untrack` to just turn off auto-logging).",
              file=sys.stderr)
        return 1
    print(f"project #{target_id} removed")


def cmd_project_set_clickup(a):
    fields = {
        "workspace_id": a.workspace_id,
        "space_id":     a.space_id,
        "space_name":   a.space_name,
        "folder_id":    a.folder_id,
        "folder_name":  a.folder_name,
        "list_id":      a.list_id,
        "list_name":    a.list_name,
    }
    if all(v is None for v in fields.values()):
        print("error: pass at least one of --workspace-id, --space-id, "
              "--space-name, --folder-id, --folder-name, --list-id, "
              "--list-name (use '' to clear)", file=sys.stderr)
        return 2
    if db.get_project(a.name) is None:
        print(f"error: no project named '{a.name}' — register it first with "
              f"`worklog project register --path <dir> --name {a.name}`",
              file=sys.stderr)
        return 1
    db.set_project_clickup_mapping(a.name, **fields)
    row = db.get_project(a.name)
    print(f"project '{row['name']}' ClickUp mapping: "
          f"workspace={row['clickup_workspace_id'] or '—'}  "
          f"space={row['clickup_space_name'] or row['clickup_space_id'] or '—'}  "
          f"folder={row['clickup_folder_name'] or row['clickup_folder_id'] or '—'}  "
          f"list={row['clickup_list_name'] or row['clickup_list_id'] or '—'}")


def _fmt_min(m: int) -> str:
    return f"{m // 60:02d}:{m % 60:02d}"


def cmd_backfill(a):
    from lib import transcripts  # local import; only needed here
    target = parse_date(a.date)
    projects = [
        r for r in db.list_projects_with_status()
        if r["path"] and r["auto_log"]
    ]
    if not projects:
        print("No projects with auto_log enabled — register one with "
              "`worklog project register --path <dir>` first.")
        return 1

    added, deduped, short = 0, 0, 0
    rows = []
    for p in projects:
        tdir = transcripts.transcript_dir(p["path"])
        if not tdir.is_dir():
            continue
        for jsonl in sorted(tdir.glob("*.jsonl")):
            for chunk in transcripts.chunk_sessions(jsonl):
                if chunk.start.astimezone().date().isoformat() != target:
                    continue
                if chunk.minutes < 2:
                    short += 1
                    continue
                start = chunk.start.astimezone()
                end = chunk.end.astimezone()
                task = chunk.first_prompt
                before = db.list_timesheet(target)
                tid = db.add_timesheet(
                    date=target,
                    since=start.strftime("%H:%M"),
                    upto=end.strftime("%H:%M"),
                    minutes=chunk.minutes,
                    project=p["name"],
                    task=task,
                    ref=f"claude-cli:backfill:{jsonl.name}",
                    source="claude-cli",
                )
                after = db.list_timesheet(target)
                was_new = len(after) > len(before)
                if was_new:
                    added += 1
                else:
                    deduped += 1
                rows.append({
                    "project": p["name"],
                    "since": start.strftime("%H:%M"),
                    "upto": end.strftime("%H:%M"),
                    "minutes": chunk.minutes,
                    "task": task[:60],
                    "action": "added" if was_new else "skipped (duplicate)",
                    "id": tid if was_new else None,
                })

    if a.format == "json":
        print(json.dumps({"date": target, "added": added, "deduped": deduped,
                          "short": short, "rows": rows}, indent=2))
        return 0

    print(f"# Backfill for {target}\n")
    if not rows:
        print("_no Claude Code sessions found in registered projects for that date_")
        return 0
    print("| #  | Project | Since | Upto | Dur  | Task                                                         | Action            |")
    print("|----|---------|-------|------|------|--------------------------------------------------------------|-------------------|")
    for r in rows:
        h, m = r["minutes"] // 60, r["minutes"] % 60
        rid = f"#{r['id']}" if r["id"] else "—"
        print(f"| {rid} | {r['project']} | {r['since']} | {r['upto']} | {h:02d}:{m:02d} | {r['task']:<60} | {r['action']:<17} |")
    print(f"\n**{added} added, {deduped} duplicates skipped, {short} too short (<2m)**")
    return 0


def cmd_show(a):
    d = parse_date(a.date)
    tasks = db.list_tasks(d)
    ts = db.list_timesheet(d)

    out = {"date": d, "tasks": [], "timesheet": [], "totals": {}}
    for r in tasks:
        out["tasks"].append({
            "id": r["id"],
            "project": r["project"],
            "task": r["task"],
            "status": r["status"],
            "status_date": r["status_date"],
            "reference": r["reference"],
            "remark": r["remark"],
            "source": r["source"],
            "clickup_task_id": r["clickup_task_id"],
        })
    total_min = 0
    for r in ts:
        out["timesheet"].append({
            "id": r["id"],
            "since": r["since"],
            "upto": r["upto"],
            "duration": _fmt_min(r["minutes"]),
            "minutes": r["minutes"],
            "project": r["project"],
            "task": r["task"],
            "ref": r["ref"],
            "source": r["source"],
        })
        total_min += r["minutes"]
    out["totals"] = {
        "tasks": len(tasks),
        "done": sum(1 for r in tasks if r["status"] == "done"),
        "minutes_logged": total_min,
        "duration_logged": _fmt_min(total_min),
    }

    if a.format == "json":
        print(json.dumps(out, indent=2))
        return

    print(_heading(f"Worklog for {d}") + "\n")
    if tasks:
        print(_subhead("Tasks"))
        for r in out["tasks"]:
            mark = "x" if r["status"] == "done" else " "
            cu = f" [cu:{r['clickup_task_id']}]" if r["clickup_task_id"] else ""
            print(f"- {_code('#' + str(r['id']))}  {_dim(r['source'] or 'manual')}  "
                  f"[{mark}] {r['project']} | {r['task']} ({r['status']}){cu}")
        print()
    else:
        print(_italic("no tasks") + "\n")
    if ts:
        print(_subhead("Timesheet"))
        for r in out["timesheet"]:
            print(f"- {_code('#' + str(r['id']))}  {_dim(r['source'] or 'manual')}  "
                  f"{r['since']}–{r['upto']} ({r['duration']})  "
                  f"{r['project']} | {r['task']}")
        print(f"\n{_ok('Total: ' + out['totals']['duration_logged'])}")
    else:
        print(_italic("no time entries"))
    if tasks or ts:
        print("\n" + _italic(
            "Use `/worklog:remove <id>` to drop a timesheet row, "
            "or `/worklog:remove task <id>` for a task."
        ))


def cmd_list_pending(a):
    d = parse_date(a.date)
    rows = db.list_tasks(d)
    pending = [
        {
            "id": r["id"],
            "project": r["project"],
            "task": r["task"],
            "status": r["status"],
            "reference": r["reference"],
            "remark": r["remark"],
            "clickup_list_id": r["clickup_list_id"],
        }
        for r in rows if not r["clickup_task_id"]
    ]
    print(json.dumps(pending, indent=2))


def cmd_link_task(a):
    db.update_task_clickup_id(a.task_id, a.clickup_id)
    print(f"task #{a.task_id} linked to ClickUp {a.clickup_id}")


def cmd_tasks_by_source(a):
    rows = db.list_tasks_by_source(a.source)
    print(json.dumps(
        [{
            "id": r["id"],
            "date": r["date"],
            "project": r["project"],
            "task": r["task"],
            "status": r["status"],
            "reference": r["reference"],
            "slack_message_ts": r["slack_message_ts"],
            "slack_last_notified": r["slack_last_notified"],
        } for r in rows],
        indent=2,
    ))


def cmd_has_reference(a):
    row = db.get_task_by_reference(a.reference)
    if row:
        print(row["id"])
        return 0
    return 1


def cmd_update_status(a):
    db.update_task_status(a.task_id, a.status, remark=a.remark)
    print(f"task #{a.task_id} -> {a.status}")


def cmd_rescan_titles(a):
    """Re-title claude-cli timesheet rows whose task is a known resume
    placeholder by re-scanning the project's transcripts."""
    from lib import transcripts
    target = parse_date(a.date)
    placeholders = {"continue from where you left off", "continue", "resume"}

    rows = db.list_timesheet(target)
    if not rows:
        print(f"no timesheet rows on {target}")
        return 0

    with db.connect() as c:
        proj_path = {r["id"]: r["path"] for r in
                     c.execute("SELECT id, path FROM projects")}

    updated, kept, no_match = 0, 0, 0
    for r in rows:
        if r["source"] != "claude-cli":
            kept += 1
            continue
        current = (r["task"] or "").strip().lower().rstrip(".!? ").strip()
        if current not in placeholders:
            kept += 1
            continue
        ppath = proj_path.get(r["project_id"])
        if not ppath:
            no_match += 1
            continue
        tdir = transcripts.transcript_dir(ppath)
        if not tdir.is_dir():
            no_match += 1
            continue

        new_title = None
        for jsonl in sorted(tdir.glob("*.jsonl")):
            for chunk in transcripts.chunk_sessions(jsonl):
                start = chunk.start.astimezone()
                if start.date().isoformat() != target:
                    continue
                if start.strftime("%H:%M") != r["since"]:
                    continue
                new_title = chunk.first_prompt
                break
            if new_title is not None:
                break

        normalised_new = (new_title or "").strip().lower().rstrip(".!? ").strip()
        if not new_title or normalised_new in placeholders:
            no_match += 1
            continue

        db.update_timesheet_task(r["id"], new_title)
        print(f"  #{r['id']}: {new_title[:90]}")
        updated += 1

    print(f"\n{updated} retitled, {kept} kept (not a placeholder), "
          f"{no_match} skipped (no matching session in transcripts)")


def cmd_retitle(a):
    """Replace the task text of a row by id."""
    if a.kind == "time":
        ok = db.update_timesheet_task(a.id, a.task)
        print(f"timesheet #{a.id} task updated" if ok
              else f"timesheet #{a.id} not found")
    else:
        ok = db.update_task_text(a.id, a.task)
        print(f"task #{a.id} task updated" if ok
              else f"task #{a.id} not found")
    return 0 if ok else 1


def cmd_link_slack(a):
    db.set_task_slack_notified(a.task_id, a.message_ts)
    print(f"task #{a.task_id} marked slack-notified ({a.message_ts})")


def cmd_list_slack_pending(_a):
    rows = db.list_tasks_needing_slack_update()
    print(json.dumps(
        [{
            "id": r["id"],
            "project": r["project"],
            "task": r["task"],
            "status": r["status"],
            "reference": r["reference"],
            "remark": r["remark"],
            "slack_message_ts": r["slack_message_ts"],
            "slack_last_notified": r["slack_last_notified"],
        } for r in rows],
        indent=2,
    ))


def cmd_set_project_list(a):
    db.set_project_clickup_list(a.project, a.list_id)
    print(f"project '{a.project}' -> ClickUp list {a.list_id}")


def _add_entry_common(parser, *, time_fields: bool = False):
    """Args shared by every 'worklog add <kind>' subcommand."""
    parser.add_argument("--date", default="today")
    parser.add_argument("--project", required=True)
    parser.add_argument("--task", required=True)
    parser.add_argument("--ref", default="")
    parser.add_argument("--source", default="manual")
    if time_fields:
        parser.add_argument("--since", required=True)
        parser.add_argument("--upto", required=True)


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="worklog")
    sub = p.add_subparsers(dest="cmd", required=True)

    sub.add_parser("init").set_defaults(func=cmd_init)

    a = sub.add_parser("add")
    a_sub = a.add_subparsers(dest="kind", required=True)

    a_task = a_sub.add_parser("task", help="add a task")
    _add_entry_common(a_task)
    a_task.add_argument("--assigned", default="")
    a_task.add_argument("--status", default="open")
    a_task.add_argument("--remark", default="")
    a_task.set_defaults(func=cmd_add_task)

    a_time = a_sub.add_parser("time", help="add a timesheet entry")
    _add_entry_common(a_time, time_fields=True)
    a_time.set_defaults(func=cmd_add_time)

    a_proj = a_sub.add_parser("project", help="register a project for auto-logging")
    a_proj.add_argument("--name", required=True)
    a_proj.add_argument("--path", help="absolute path to project root (enables auto-log when cwd matches)")
    a_proj.add_argument("--coordinator", default="")
    a_proj.add_argument("--repo", default="")
    a_proj.add_argument("--no-auto-log", action="store_true",
                        help="register but skip the SessionEnd auto-log for this path")
    a_proj.set_defaults(func=cmd_add_project)

    pr = sub.add_parser("projects", help="list registered projects with status")
    pr.add_argument("--format", choices=["text", "json"], default="text")
    pr.set_defaults(func=cmd_projects)

    rm = sub.add_parser(
        "remove",
        help="remove a timesheet (default) or task entry by id. "
             "Usage: worklog remove <id> | worklog remove time <id> | worklog remove task <id>",
    )
    rm.add_argument("kind_or_id", help="'time' | 'task' | <id>  (bare id = timesheet)")
    rm.add_argument("id", nargs="?", type=int,
                    help="entry id (required when kind_or_id is 'time' or 'task')")
    rm.set_defaults(func=cmd_remove)

    proj = sub.add_parser("project", help="register / untrack a project by path")
    proj_sub = proj.add_subparsers(dest="action", required=True)
    proj_reg = proj_sub.add_parser("register",
                                   help="register a project for auto-logging (defaults name to basename of path)")
    proj_reg.add_argument("--path", required=True)
    proj_reg.add_argument("--name")
    proj_reg.add_argument("--coordinator", default="")
    proj_reg.add_argument("--repo", default="")
    proj_reg.set_defaults(func=cmd_project_register)
    proj_unt = proj_sub.add_parser("untrack",
                                   help="turn auto-logging off for the project covering this path")
    proj_unt.add_argument("--path", required=True)
    proj_unt.set_defaults(func=cmd_project_untrack)

    proj_rm = proj_sub.add_parser("remove",
                                  help="delete a project row (fails if tasks or timesheet rows reference it)")
    proj_rm.add_argument("--id", type=int, default=None)
    proj_rm.add_argument("--name", default=None)
    proj_rm.set_defaults(func=cmd_project_remove)

    proj_sh = proj_sub.add_parser("show",
                                  help="print a single project's name + path + auto-log + ClickUp breadcrumb")
    proj_sh.add_argument("--id", type=int, default=None)
    proj_sh.add_argument("--name", default=None)
    proj_sh.add_argument("--path", default=None)
    proj_sh.set_defaults(func=cmd_project_show)

    proj_cu = proj_sub.add_parser("set-clickup",
                                  help="map a project to ClickUp Workspace/Space/Folder/List (pass '' to clear)")
    proj_cu.add_argument("--name", required=True)
    proj_cu.add_argument("--workspace-id", dest="workspace_id", default=None,
                         help="ClickUp workspace id — needed to build clickable URLs in /worklog:projects")
    proj_cu.add_argument("--space-id",    dest="space_id",    default=None)
    proj_cu.add_argument("--space-name",  dest="space_name",  default=None)
    proj_cu.add_argument("--folder-id",   dest="folder_id",   default=None)
    proj_cu.add_argument("--folder-name", dest="folder_name", default=None)
    proj_cu.add_argument("--list-id",     dest="list_id",     default=None)
    proj_cu.add_argument("--list-name",   dest="list_name",   default=None)
    proj_cu.set_defaults(func=cmd_project_set_clickup)

    s = sub.add_parser("show")
    s.add_argument("date", nargs="?", default="today")
    s.add_argument("--format", choices=["text", "json"], default="text")
    s.set_defaults(func=cmd_show)

    bf = sub.add_parser("backfill",
                        help="scan transcripts of registered projects and insert any missing timesheet rows for date")
    bf.add_argument("date", nargs="?", default="today")
    bf.add_argument("--format", choices=["text", "json"], default="text")
    bf.set_defaults(func=cmd_backfill)

    lp = sub.add_parser("list-pending")
    lp.add_argument("date", nargs="?", default="today")
    lp.set_defaults(func=cmd_list_pending)

    lt = sub.add_parser("link-task")
    lt.add_argument("task_id", type=int)
    lt.add_argument("clickup_id")
    lt.set_defaults(func=cmd_link_task)

    tbs = sub.add_parser("tasks-by-source",
                         help="list all tasks (any date) with a given source tag")
    tbs.add_argument("source")
    tbs.set_defaults(func=cmd_tasks_by_source)

    hr = sub.add_parser("has-reference",
                        help="check if any task already has this reference; prints id and exits 0 if yes")
    hr.add_argument("reference")
    hr.set_defaults(func=cmd_has_reference)

    us = sub.add_parser("update-status",
                        help="update a task's status and status_date")
    us.add_argument("task_id", type=int)
    us.add_argument("status")
    us.add_argument("--remark", default=None)
    us.set_defaults(func=cmd_update_status)

    rs = sub.add_parser("rescan-titles",
                        help="re-title claude-cli timesheet rows whose task is a known resume placeholder, "
                             "by re-extracting from the project's transcripts")
    rs.add_argument("date", nargs="?", default="today")
    rs.set_defaults(func=cmd_rescan_titles)

    rt = sub.add_parser("retitle",
                        help="replace the task text on a timesheet or tasks row by id")
    rt_sub = rt.add_subparsers(dest="kind", required=True)
    rt_time = rt_sub.add_parser("time")
    rt_time.add_argument("id", type=int)
    rt_time.add_argument("task")
    rt_time.set_defaults(func=cmd_retitle)
    rt_task = rt_sub.add_parser("task")
    rt_task.add_argument("id", type=int)
    rt_task.add_argument("task")
    rt_task.set_defaults(func=cmd_retitle)

    ls = sub.add_parser("link-slack",
                        help="mark a task as notified to Slack at message_ts")
    ls.add_argument("task_id", type=int)
    ls.add_argument("message_ts")
    ls.set_defaults(func=cmd_link_slack)

    lsp = sub.add_parser("list-slack-pending",
                         help="JSON list of Slack-sourced tasks whose status changed since last notification")
    lsp.set_defaults(func=cmd_list_slack_pending)

    sp = sub.add_parser("set-project-list")
    sp.add_argument("project")
    sp.add_argument("list_id")
    sp.set_defaults(func=cmd_set_project_list)

    return p


def main():
    args = build_parser().parse_args()
    rc = args.func(args)
    sys.exit(rc or 0)


if __name__ == "__main__":
    main()
